# Copy to apps/next/.env.local — NEVER commit the filled file.
# WDK Indexer (live balances / activity). Obtain from Tether WDK docs.
WDK_INDEXER_BASE_URL=
WDK_INDEXER_API_KEY=

# CSP connect-src extra origins (comma-separated). Add your Electrum-WS origin here
# to tighten egress from the default wholesale wss: to the exact endpoint, e.g.:
#   NEXT_PUBLIC_CONNECT_SRC_ORIGINS=wss://electrum.example.com:50004
# Also accepts https:// origins for custom indexer/price/RPC endpoints.
NEXT_PUBLIC_CONNECT_SRC_ORIGINS=
