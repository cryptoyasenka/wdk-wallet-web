# Copy to .env.local. All values are PUBLIC (the wallet runs entirely in the
# browser), hence the NEXT_PUBLIC_ prefix. No secrets belong in this file.

# Comma-separated Ethereum RPC URLs. WDK's EVM manager treats the list as a
# native failover chain. Public nodes are rate-limited — override with a keyed
# RPC for anything beyond a demo. Defaults to wallet-core's keyless list.
NEXT_PUBLIC_ETHEREUM_RPC_URLS=https://ethereum-rpc.publicnode.com,https://eth.llamarpc.com

# Bitcoin Electrum-over-WebSocket endpoint (wss://). The browser cannot open a
# raw Electrum TCP socket and there is no universal public Electrum-WS server,
# so BTC is registered ONLY when this is set. Leave empty to ship Ethereum-only
# (BTC then surfaces a typed UnsupportedChainError instead of failing silently).
# Form (NOT a default — run/choose your own; comma-separate several and WDK
# rotates them via @tetherto/wdk-failover-provider):
#   NEXT_PUBLIC_BTC_ELECTRUM_WS_URL=wss://your-electrum-host:50004
NEXT_PUBLIC_BTC_ELECTRUM_WS_URL=

# Extra origins to add to the Content-Security-Policy connect-src allow-list,
# comma-separated. Use this when self-hosting against a custom indexer, price
# oracle, or RPC whose origin isn't shipped by default: it lets the browser
# reach that origin WITHOUT also registering it as an Ethereum RPC (which is
# what putting it in NEXT_PUBLIC_ETHEREUM_RPC_URLS would do). Origins only
# (scheme://host[:port]); any path is ignored. If you list a wss:// Electrum
# origin here, the CSP drops the default wholesale `wss:` scheme and permits
# only the pinned secure-WebSocket origin(s), tightening egress for production.
#   NEXT_PUBLIC_CONNECT_SRC_ORIGINS=wss://electrum.example.com:50004,https://indexer.example.com,https://prices.example.com
NEXT_PUBLIC_CONNECT_SRC_ORIGINS=
